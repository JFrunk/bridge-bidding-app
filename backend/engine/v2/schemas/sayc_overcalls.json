      "bid": "X",
      "priority": 830,
      "description": "Balancing takeout double with borrowed values (9+ HCP)",
      "constraints": [
        {"feature": "is_balancing", "expected": true, "constraint_type": "HARD"},
        {"feature": "hcp", "min": 9, "constraint_type": "SOFT"},
        {"feature": "perfect_takeout_shape", "expected": true, "constraint_type": "HARD"}
