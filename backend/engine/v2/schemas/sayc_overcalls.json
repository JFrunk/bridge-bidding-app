{
  "schema_version": "1.0",
  "system": "SAYC",
  "category": "overcalls",
  "description": "Overcalls and competitive bidding - direct seat actions",
  "rules": [
    {
      "id": "1nt_overcall",
      "bid": "1NT",
      "priority": 800,
      "description": "Direct 1NT overcall (15-18 HCP balanced with stopper)",
      "constraints": [
        {"feature": "is_overcall", "expected": true, "constraint_type": "HARD"},
        {"feature": "is_balancing", "expected": false, "constraint_type": "HARD"},
        {"feature": "my_bid_count", "max": 0, "constraint_type": "HARD"},
        {"feature": "hcp", "min": 15, "max": 18, "constraint_type": "SOFT", "penalty_per_unit": 0.1},
        {"feature": "is_balanced", "expected": true, "constraint_type": "HARD"},
        {"feature": "stopper_in_opponent_suit", "expected": true, "constraint_type": "HARD"}
      ],
      "forcing": "none",
      "explanation": "1NT overcall (15-18 HCP, balanced with stopper)",
      "sets_forcing_level": "NON_FORCING"
    },
    {
      "id": "overcall_1_level_spades",
      "bid": "1♠",
      "priority": 720,
      "description": "1♠ overcall with 5+ spades",
      "constraints": [
        {"feature": "is_overcall", "expected": true, "constraint_type": "HARD"},
        {"feature": "is_balancing", "expected": false, "constraint_type": "HARD"},
        {"feature": "my_bid_count", "max": 0, "constraint_type": "HARD"},
        {"feature": "hcp", "min": 8, "max": 16, "constraint_type": "SOFT", "penalty_per_unit": 0.1},
        {"feature": "spades_length", "min": 5, "constraint_type": "HARD"},
        {"feature": "spades_quality", "min": 2, "constraint_type": "SOFT", "penalty_per_unit": 0.2}
      ],
      "forcing": "none",
      "explanation": "1\u2660 overcall (8-16 HCP, 5+ spades)",
      "sets_forcing_level": "NON_FORCING"
    },
