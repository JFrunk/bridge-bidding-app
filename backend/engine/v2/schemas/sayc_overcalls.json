      "id": "balancing_1nt_overcall",
      "bid": "1NT",
      "priority": 825,
      "description": "Balancing 1NT (11-14 HCP instead of standard 15-18)",
      "constraints": [
        {"feature": "is_balancing", "expected": true, "constraint_type": "HARD"},
        {"feature": "hcp", "min": 11, "max": 14, "constraint_type": "HARD"},
        {"feature": "is_balanced", "expected": true, "constraint_type": "HARD"},
        {"feature": "stopper_in_opponent_suit", "expected": true, "constraint_type": "HARD"}
      ],
      "forcing": "none",
      "explanation": "Balancing 1NT showing 11-14 HCP and a stopper in opponent's suit",
      "sets_forcing_level": "NON_FORCING"
    },
    {
      "id": "1nt_overcall_balancing",
      "bid": "1NT",
      "priority": 94,
      "description": "Balancing 1NT",
      "conditions": {
        "is_overcall": true,
        "is_balancing": true,
        "hcp": {
          "min": 12,
          "max": 15
